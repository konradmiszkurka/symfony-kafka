{% extends 'base.html.twig' %}
{% block title %}{{ course.title }}{% endblock %}
{% block body %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}<div class="alert {{ label }}">{{ message }}</div>{% endfor %}
    {% endfor %}

    <h1>{{ course.title }}</h1>
    <p>{{ course.description }}</p>
    {% if progress is defined and progress is not null %}
        <p>Twój postęp: {{ progress.percentage }}% ({{ progress.completedLessons }}/{{ progress.totalLessons }}){% if progress.completed %} — ukończono!{% endif %}</p>
    {% endif %}
    {% for section in course.sections %}
        <h2>{{ section.title }}</h2>
        <ol>
        {% for lesson in section.lessons %}
            <li>{{ lesson.title }}
                {% if is_granted('ROLE_USER') %}
                    <form method="post" action="{{ path('progress_mark_lesson', {courseId: course.id, lessonId: lesson.id}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('complete-' ~ lesson.id) }}">
                        <button type="submit">Ukończ</button>
                    </form>
                {% endif %}
            </li>
        {% endfor %}
        </ol>
    {% endfor %}

    {% if is_granted('ROLE_USER') %}
        <form method="post" action="{{ path('enroll', {id: course.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('enroll-' ~ course.id) }}">
            <button type="submit">Zapisz się</button>
        </form>
    {% else %}
        <p><a href="{{ path('login') }}">Zaloguj się, aby zapisać się na kurs</a></p>
    {% endif %}
{% endblock %}
